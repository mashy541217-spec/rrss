{
  "name": "rrss-auto",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "jest",
    "build:domain": "npm run build --workspace=packages/domain",
    "build:application": "npm run build --workspace=packages/application",
    "build:infrastructure": "npm run build --workspace=packages/infrastructure",
    "build:testing": "npm run build --workspace=packages/testing",
    "build:logger": "npm run build --workspace=packages/logger",
    "build:configuration": "npm run build --workspace=packages/configuration",
    "build:observability": "npm run build --workspace=packages/observability"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.11",
    "rimraf": "^5.0.5"
  }
}
