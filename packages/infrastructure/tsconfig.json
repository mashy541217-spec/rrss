{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@rrss-auto/domain": ["../domain/src/index.ts"],
      "@rrss-auto/application": ["../application/src/index.ts"],
      "@rrss-auto/logger": ["../logger/src/index.ts"],
      "@rrss-auto/configuration": ["../configuration/src/index.ts"],
      "@rrss-auto/observability": ["../observability/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
