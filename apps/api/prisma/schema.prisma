generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OutboxMessage {
  id            String    @id @default(uuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        String    @default("PENDING")
  retries       Int       @default(0)
  error         String?
  createdAt     DateTime  @default(now())
  processedAt   DateTime?

  @@index([status, createdAt])
}

model Workspace {
  id        String    @id
  name      String
  slug      String    @unique
  ownerId   String
  status    String
  settings  Json
  limits    Json
  version   Int       @default(1)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([ownerId])
  @@index([status])
}

model Business {
  id           String    @id
  workspaceRef String
  name         String
  category     String
  logoUrl      String?
  brandColor   String?
  emailBrand   Json      @default("{}")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([workspaceRef])
}

model User {
  id           String    @id
  email        String    @unique
  displayName  String
  passwordHash String
  status       String
  version      Int       @default(1)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([status])
}

model Membership {
  id           String    @id
  userId       String
  workspaceRef String
  roleId       String
  status       String
  version      Int       @default(1)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([workspaceRef])
  @@index([status])
}

model WorkspaceRole {
  id           String    @id
  name         String
  description  String
  workspaceRef String
  permissions  String[]
  status       String
  version      Int       @default(1)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([workspaceRef])
  @@index([status])
}

model Invitation {
  id           String    @id
  email        String
  workspaceRef String
  roleId       String
  token        String
  status       String
  expiresAt    DateTime
  version      Int       @default(1)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([workspaceRef])
  @@index([token])
  @@index([status])
}

model Execution {
  id               String              @id
  workspaceRef     String
  idempotencyKey   String              @unique
  status           String
  retryPolicy      Json
  attemptsMade     Int                 @default(0)
  totalSteps       Int                 @default(0)
  completedSteps   Int                 @default(0)
  assignedWorkerId String?
  failure          Json?
  version          Int                 @default(1)
  isDeleted        Boolean             @default(false)
  deletedAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  metadata         ExecutionMetadata?
  steps            ExecutionStep[]
  timeline         ExecutionTimeline[]
  jobs             Job[]

  @@index([workspaceRef])
  @@index([status])
  @@index([assignedWorkerId])
}

model ExecutionMetadata {
  id           String    @id @default(uuid())
  executionId  String    @unique
  actor        String
  intent       String
  priority     String
  capabilities Json
  execution    Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
}

model ExecutionTimeline {
  id          String    @id @default(uuid())
  executionId String
  status      String
  occurredAt  DateTime
  message     String
  actor       String?
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, occurredAt])
}

model ExecutionStep {
  id             String    @id
  executionId    String
  order          Int
  name           String
  description    String
  capabilityType String
  idempotencyKey String
  status         String
  output         String?
  failure        Json?
  retryAttempts  Int       @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  version        Int       @default(1)
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  execution      Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@unique([executionId, idempotencyKey])
  @@index([executionId, order])
  @@index([status])
}

model Job {
  id                String             @id
  executionId       String
  stepId            String?
  workspaceRef      String
  status            String
  priority          String
  queue             String
  claimedByWorkerId String?
  claimedAt         DateTime?
  attempts          Int                @default(0)
  maxAttempts       Int                @default(3)
  enqueuedAt        DateTime?
  leaseExpiresAt    DateTime?
  version           Int                @default(1)
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  execution         Execution          @relation(fields: [executionId], references: [id], onDelete: Cascade)
  assignments       WorkerAssignment[]

  @@index([executionId])
  @@index([status])
  @@index([queue])
  @@index([claimedByWorkerId])
}

model WorkerAssignment {
  id             String   @id @default(uuid())
  jobId          String
  workerId       String
  claimedAt      DateTime @default(now())
  leaseExpiresAt DateTime
  status         String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([workerId])
}

model Scheduler {
  id                    String    @id
  status                String
  concurrencyPolicy     Json
  workerSelectionPolicy Json
  priorityPolicy        Json
  retryPolicy           Json
  version               Int       @default(1)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Schedule {
  id                String    @id
  workspaceRef      String
  status            String
  schedulingPolicy  Json
  priorityPolicy    Json
  concurrencyPolicy Json?
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  version           Int       @default(1)
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([workspaceRef])
  @@index([status])
  @@index([nextRunAt])
}

model ExecutionReservation {
  id          String    @id
  executionId String
  workerId    String
  status      String
  reservedAt  DateTime
  expiresAt   DateTime
  version     Int       @default(1)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([executionId])
  @@index([workerId])
  @@index([status])
}

model CapacityManager {
  id             String    @id
  status         String
  globalLimits   Json
  reservedLimits Json
  version        Int       @default(1)
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ResourcePool {
  id            String    @id
  name          String
  totalCapacity Json
  usedCapacity  Json
  status        String
  version       Int       @default(1)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ResourceReservation {
  id           String    @id
  poolId       String
  resourceType String
  amount       Int
  status       String
  expiresAt    DateTime
  version      Int       @default(1)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([poolId])
}

model ResourceLease {
  id        String    @id
  workerId  String
  poolId    String
  resources Json
  status    String
  grantedAt DateTime
  expiresAt DateTime
  version   Int       @default(1)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([workerId])
  @@index([poolId])
  @@index([status])
}

model Worker {
  id               String                @id
  hostname         String                @unique
  status           String
  capabilities     Json
  currentJobId     String?
  concurrencyLimit Int
  activeJobCount   Int
  registeredAt     DateTime
  version          Int                   @default(1)
  isDeleted        Boolean               @default(false)
  deletedAt        DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  assignments      ExecutionAssignment[]
  heartbeats       WorkerHeartbeat[]
  sessions         WorkerSession[]

  @@index([status])
}

model WorkerSession {
  id        String    @id
  workerId  String
  startedAt DateTime
  endedAt   DateTime?
  status    String
  version   Int       @default(1)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  worker    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
}

model WorkerHeartbeat {
  id          String    @id
  workerId    String
  receivedAt  DateTime
  cpuUsage    Float?
  memoryUsage Float?
  status      String
  version     Int       @default(1)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  worker      Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, receivedAt])
}

model ExecutionAssignment {
  id          String    @id
  workerId    String
  executionId String
  jobId       String
  status      String
  assignedAt  DateTime
  completedAt DateTime?
  version     Int       @default(1)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  worker      Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([executionId])
  @@index([jobId])
}

model Credential {
  id         String             @id
  name       String
  type       String
  status     String
  provider   String
  scope      String
  ownerId    String
  metadata   Json               @default("{}")
  policy     Json               @default("{}")
  version    Int                @default(1)
  isDeleted  Boolean            @default(false)
  deletedAt  DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  businessId String?
  secrets    CredentialSecret[]

  @@index([ownerId])
  @@index([status])
  @@index([type])
  @@index([businessId])
}

model CredentialSecret {
  id                     String     @id
  credentialId           String
  version                Int
  encryptedValue         String
  algorithm              String
  encryptionKeyReference String?
  vaultReference         String?
  isActive               Boolean    @default(true)
  createdAt              DateTime   @default(now())
  credential             Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@unique([credentialId, version])
  @@index([credentialId])
}

model Content {
  id           String            @id
  workspaceRef String
  status       String
  title        String?
  body         String?
  metadata     Json              @default("{}")
  analytics    Json              @default("{}")
  version      Int               @default(1)
  isDeleted    Boolean           @default(false)
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  versions     ContentVersion[]
  collections  MediaCollection[]

  @@index([workspaceRef])
  @@index([status])
}

model ContentVersion {
  id        String   @id
  contentId String
  version   Int
  changes   Json     @default("{}")
  createdAt DateTime @default(now())
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, version])
  @@index([contentId])
}

model Asset {
  id           String      @id
  workspaceRef String
  status       String
  mediaType    String
  mimeType     String
  checksum     String?
  fileSize     BigInt?
  metadata     Json        @default("{}")
  version      Int         @default(1)
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  businessId   String?
  mediaFiles   MediaFile[]

  @@index([workspaceRef])
  @@index([mediaType])
  @@index([status])
  @@index([businessId])
}

model MediaFile {
  id        String   @id
  assetId   String
  url       String
  bucket    String?
  key       String?
  size      BigInt
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model MediaCollection {
  id         String    @id
  contentId  String
  name       String
  type       String
  mediaItems Json      @default("[]")
  version    Int       @default(1)
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  content    Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

model ContentTemplate {
  id           String    @id
  workspaceRef String
  name         String
  description  String?
  schema       Json      @default("{}")
  defaultData  Json      @default("{}")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([workspaceRef])
}

model PublicationProfile {
  id           String    @id
  workspaceRef String
  name         String
  targets      Json      @default("[]")
  settings     Json      @default("{}")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([workspaceRef])
}

model Campaign {
  id              String                   @id
  workspaceRef    String
  name            String
  description     String?
  status          String
  priority        String
  objective       String
  strategy        String
  tags            String[]
  budget          Json
  schedule        Json?
  audience        Json?
  goals           Json?
  analytics       Json?
  version         Int                      @default(1)
  isDeleted       Boolean                  @default(false)
  deletedAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  businessId      String?
  channels        CampaignChannel[]
  contents        CampaignContent[]
  executions      CampaignExecution[]
  metricSnapshots CampaignMetricSnapshot[]
  publications    Publication[]

  @@index([workspaceRef])
  @@index([status])
  @@index([businessId])
}

model Publication {
  id          String    @id
  campaignId  String
  status      String
  format      String
  contentId   String
  publishAt   DateTime?
  publishedAt DateTime?
  url         String?
  externalId  String?
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model CampaignChannel {
  id            String   @id
  campaignId    String
  platform      String
  type          String
  configuration Json     @default("{}")
  createdAt     DateTime @default(now())
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model CampaignContent {
  id         String   @id
  campaignId String
  contentId  String
  attachedAt DateTime @default(now())
  attachedBy String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model CampaignExecution {
  id            String   @id
  campaignId    String
  executionId   String
  publicationId String?
  status        String
  triggeredAt   DateTime @default(now())
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model CampaignMetricSnapshot {
  id         String   @id
  campaignId String
  recordedAt DateTime @default(now())
  metrics    Json     @default("{}")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model Automation {
  id            String               @id
  workspaceRef  String
  name          String
  description   String?
  status        String
  variables     Json                 @default("[]")
  trigger       Json?
  retryConfig   Json?
  timeoutConfig Json?
  executionPlan Json?
  version       Int                  @default(1)
  isDeleted     Boolean              @default(false)
  deletedAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  businessId    String?
  snapshots     AutomationSnapshot[]
  versions      AutomationVersion[]
  connections   WorkflowConnection[]
  nodes         WorkflowNode[]

  @@index([workspaceRef])
  @@index([status])
  @@index([businessId])
}

model WorkflowNode {
  id           String     @id
  automationId String
  type         String
  name         String
  config       Json       @default("{}")
  positionX    Float      @default(0)
  positionY    Float      @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
}

model WorkflowConnection {
  id           String     @id
  automationId String
  sourceId     String
  targetId     String
  sourceHandle String?
  targetHandle String?
  condition    String?
  createdAt    DateTime   @default(now())
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
}

model AutomationVersion {
  id            String     @id
  automationId  String
  versionNumber Int
  status        String
  trigger       Json?
  nodes         Json       @default("[]")
  connections   Json       @default("[]")
  variables     Json       @default("[]")
  executionPlan Json?
  createdAt     DateTime   @default(now())
  automation    Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@unique([automationId, versionNumber])
  @@index([automationId])
}

model AutomationSnapshot {
  id           String     @id
  automationId String
  snapshotData Json       @default("{}")
  createdAt    DateTime   @default(now())
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
}
